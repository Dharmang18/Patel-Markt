# Stripe
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal
NEXT_PUBLIC_PAYPAL_CLIENT_ID=...

# Store
NEXT_PUBLIC_STORE_URL=https://patel-markt.de

# WhatsApp Cloud API (server-side order delivery to the merchant)
# Orders are sent from the server so customer details never appear in a URL.
WHATSAPP_TOKEN=EAA...                  # Cloud API access token
WHATSAPP_PHONE_NUMBER_ID=...           # Business phone number ID (sender)
WHATSAPP_MERCHANT_NUMBER=4917425137501 # Merchant recipient, international format, no '+'
# Note: WhatsApp's Cloud API only allows free-form text within a 24h customer
# service window. For guaranteed delivery outside that window, use an approved
# message template instead.

# Supabase (database + user authentication)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server-only, never expose to the client

# Admin panel login (seller). Defaults shown if unset.
ADMIN_USERNAME=patelmarkt
ADMIN_PASSWORD=patelmarktadmin
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string

# Bank transfer details (shown to customer)
NEXT_PUBLIC_BANK_IBAN=DE...
NEXT_PUBLIC_BANK_BIC=...
NEXT_PUBLIC_BANK_NAME=Patel Markt GmbH
