# Stripe
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal
NEXT_PUBLIC_PAYPAL_CLIENT_ID=...

# Store
NEXT_PUBLIC_STORE_URL=https://patel-markt.de

# WhatsApp via Twilio (server-side order delivery to the merchant).
# Orders are sent automatically from the server — the customer never sees it.
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # Twilio sandbox/sender number
TWILIO_WHATSAPP_TO=whatsapp:+4915906306724   # Patel Markt receiving number (optional; defaults to this)
# Sandbox note: the receiving number must first join the sandbox once by
# sending the "join <code>" message shown in the Twilio console.

# Supabase (database + user authentication)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server-only, never expose to the client

# Cloudflare R2 — product image storage (replaces Supabase Storage).
# Create a bucket, an R2 API token (Object Read & Write), and enable public
# access (r2.dev) or attach a custom domain. See docs/SETUP-R2.md.
R2_ACCOUNT_ID=...                       # Cloudflare account ID
R2_ACCESS_KEY_ID=...                    # R2 API token access key
R2_SECRET_ACCESS_KEY=...                # R2 API token secret key  (server-only)
R2_BUCKET=product-images                # bucket name
R2_PUBLIC_URL=https://pub-xxxx.r2.dev   # public bucket base URL, no trailing slash
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-xxxx.r2.dev  # same value, exposed to client (hero image)

# Admin panel login (seller). Defaults shown if unset.
ADMIN_USERNAME=patelmarkt
ADMIN_PASSWORD=patelmarktadmin
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string

# Email notifications (Resend) — emails the seller when a new account is created
RESEND_API_KEY=re_...
ADMIN_NOTIFY_EMAIL=seller@example.com   # where signup alerts are sent
# RESEND_FROM="Patel Markt <orders@yourdomain.de>"  # optional; defaults to Resend's shared sender

# Bank transfer details (shown to customer)
NEXT_PUBLIC_BANK_IBAN=DE...
NEXT_PUBLIC_BANK_BIC=...
NEXT_PUBLIC_BANK_NAME=Patel Markt GmbH
